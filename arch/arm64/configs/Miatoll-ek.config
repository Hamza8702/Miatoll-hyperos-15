#
# Android 15 & HyperOS Core Requirements
#
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=n
CONFIG_SCHED_WALT=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_BUCKETS_COUNT=20
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_FUSE_BPF=y
CONFIG_INCREMENTAL_FS=y

#
# KVM & Virtualization Support (Full Enable)
#
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_ARM_HOST=y
CONFIG_KVM_ARM_PMU=y
CONFIG_ARM64_VHE=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y

#
# KernelSU Support
#
CONFIG_KSU=y
CONFIG_OVERLAY_FS=y

#
# Optimization & Compiler Settings (Clang/LLVM)
#
CONFIG_LTO_CLANG=y
CONFIG_THINLTO=y
CONFIG_LLVM_POLLY=y
CONFIG_INLINE_OPTIMIZATION=y
CONFIG_SHADOW_CALL_STACK=y

#
# Memory Management & Storage
#
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZSMALLOC=y
CONFIG_BLK_INLINE_ENCRYPTION=y
CONFIG_BLK_INLINE_ENCRYPTION_FALLBACK=y
CONFIG_FS_ENCRYPTION_INLINE_CRYPT=y

#
# Networking & Wireguard
#
CONFIG_NET=y
CONFIG_INET=y
CONFIG_WIREGUARD=y

#
# Device Specific (Miatoll)
#
CONFIG_MACH_XIAOMI_MIATOLL=y
CONFIG_FRAME_WARN=0
